# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=AniSlots
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── Slot Engine ────────────────────────────────────────────
RNG_SECRET_SEED=
JACKPOT_INCREMENT_RATE=0.01
JACKPOT_WIN_PROBABILITY=0.0001
NEXT_PUBLIC_JACKPOT_SEED=50000
NEXT_PUBLIC_MIN_BET=10
NEXT_PUBLIC_MAX_BET=10000

# ─── Crypto Payments (fase 2) ───────────────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NEXT_PUBLIC_CRYPTO_ENABLED=false

# ─── Feature Flags ──────────────────────────────────────────
NEXT_PUBLIC_CHAT_ENABLED=true
NEXT_PUBLIC_JACKPOT_ENABLED=true
NEXT_PUBLIC_BONUS_ROUND_ENABLED=true
